{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "devCommand": "npx expo start --web --port $PORT",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
