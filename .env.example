# Plus One — env var schema
# Copy to .env.local and fill in real values. .env.local is gitignored.

# ============================================
# Supabase (REQUIRED)
# ============================================
# Project: utoykngdauuglqttjlvw (PlusOne)
# Anon key is designed-public (RLS protects data) but rotates during cleanup.
# Get the current anon key: https://supabase.com/dashboard/project/utoykngdauuglqttjlvw/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://utoykngdauuglqttjlvw.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ============================================
# Mapbox (OPTIONAL — required to ship the map view)
# ============================================
# Free tier: 50K loads/month
# Get token: https://account.mapbox.com/access-tokens/
# EXPO_PUBLIC_MAPBOX_TOKEN=

# ============================================
# Server-side / Edge Function secrets (DO NOT prefix with EXPO_PUBLIC_)
# ============================================
# These belong in Supabase Edge Function secrets, NOT here.
# Listed for reference so you know what the project depends on:
#
# APIFY_API_TOKEN          → Facebook Events scraper (apify.com)
# GOOGLE_PLACES_API_KEY    → Venue enrichment (console.cloud.google.com)
# ANTHROPIC_API_KEY        → optional, only if Claude API is wired
# YELP_API_KEY             → restaurant data (yelp.com/developers)
# EVENTBRITE_API_TOKEN     → event ingestion (eventbrite.com/platform/api-keys)
